{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/services/layout,_N_T_/[lang]/services/page,_N_T_/es/services"},"segmentPaths":["/_tree","/_full","/$d$lang/services/__PAGE__","/$d$lang/services","/$d$lang","/_index","/_head"]},"html":"<!DOCTYPE html><html class=\"open_sans_573b549b-module__BY3tqa__variable h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/cf514f5d0007dafa-s.p.1wc2mf9hp9pav.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" href=\"/images/Logos-SafetyLink-5.png\"/><link rel=\"preload\" href=\"/images/Logos-SafetyLink-1.png\" as=\"image\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/305zfmpkz2n9r.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/3z5q_p4msz2ha.js\"/><script src=\"/_next/static/chunks/15orcrkp-_9ct.js\" async=\"\"></script><script src=\"/_next/static/chunks/2nykiepra7i1k.js\" async=\"\"></script><script src=\"/_next/static/chunks/07u_h6i539_wj.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3gtektv3c62t6.js\" async=\"\"></script><script src=\"/_next/static/chunks/05-c3ty_6dwfk.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/1-z_8zqv2wo99.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>SafetyLink | Legally Defensible Safety Compliance</title><meta name=\"description\" content=\"The Gold Standard in Legally Defensible Safety that Protects Your People and Your Business.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><html lang=\"es\"><header class=\"bg-white shadow-sm sticky top-0 z-50\"><div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\"><a class=\"flex items-center gap-3\" href=\"/es\"><img src=\"/images/Logos-SafetyLink-5.png\" alt=\"SafetyLink\" class=\"h-10 w-auto\"/></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es\">Inicio</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/solutions\">Soluciones</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/services\">Servicios</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/about\">Nosotros</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/contact\">Contacto</a><a class=\"bg-primary text-white px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-[#009c2f] transition-colors\" href=\"/es/contact\">Solicitar Demo</a><a class=\"text-[#686868] font-medium text-sm hover:text-primary transition-colors\" href=\"https://app.safetylink.ai\">Ingresar</a><a class=\"text-xs text-navy font-semibold bg-[#eef3ff] px-3 py-1.5 rounded-full hover:bg-navy hover:text-white transition-all\" href=\"/en\">EN</a></nav><button class=\"lg:hidden text-navy p-2\" aria-label=\"Menu\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></header><main class=\"flex-1\"><section class=\"bg-navy text-white py-20 px-6 text-center\"><div class=\"max-w-3xl mx-auto\"><h1 class=\"text-3xl md:text-5xl font-bold mb-4\">Nuestros Servicios</h1><p class=\"text-gray-300 text-lg\">Soluciones integrales de seguridad y cumplimiento adaptadas a su negocio.</p></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">🔍</div><h3 class=\"font-bold text-navy mb-2\">Auditorías e Inspecciones de Seguridad</h3><p class=\"text-[#666] text-sm\">Evaluaciones de riesgos en sitio y auditorías de cumplimiento para identificar riesgos antes que OSHA.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">📚</div><h3 class=\"font-bold text-navy mb-2\">Capacitación OSHA (EN/ES)</h3><p class=\"text-[#666] text-sm\">Capacitación bilingüe impartida por capacitadores autorizados por OSHA — en sitio o remota.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">📋</div><h3 class=\"font-bold text-navy mb-2\">Desarrollo de Políticas y Programas</h3><p class=\"text-[#666] text-sm\">Políticas de seguridad específicas por sitio, JHAs, JSAs y planes de emergencia.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">⚖️</div><h3 class=\"font-bold text-navy mb-2\">Defensa de Citaciones y Soporte</h3><p class=\"text-[#666] text-sm\">Si OSHA aparece, nosotros aparecemos — orientación, representación y planes de acción correctiva.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">🔎</div><h3 class=\"font-bold text-navy mb-2\">Investigación de Incidentes</h3><p class=\"text-[#666] text-sm\">Análisis de causa raíz, documentación y estrategias de prevención.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">🛡️</div><h3 class=\"font-bold text-navy mb-2\">Consultoría de Riesgos y Seguros</h3><p class=\"text-[#666] text-sm\">Revisión de reclamos de compensación laboral, evaluaciones de riesgos y recomendaciones.</p></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-3xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy mb-4\">¿No está seguro de lo que necesita?</h2><p class=\"text-[#666] text-lg mb-8\">Hable con un Asesor Autorizado por OSHA — lo ayudaremos a encontrar la solución adecuada.</p><a class=\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \" href=\"/contact\">Solicitar Consultoría</a></div></section></main><footer class=\"bg-navy text-white\"><div class=\"max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-10\"><div><img src=\"/images/Logos-SafetyLink-1.png\" alt=\"SafetyLink\" class=\"h-8 w-auto mb-4\"/><p class=\"text-gray-300 text-sm leading-relaxed mb-4\">La única plataforma de cumplimiento de seguridad legalmente defendible respaldada por ex-liderazgo de OSHA y expertos en derecho laboral. Protegiendo fuerzas laborales con capacitación, auditorías y soluciones de cumplimiento bilingües.</p><p class=\"text-xs text-gray-400 italic\">SafetyLink no está afiliado ni respaldado por OSHA. El apoyo consultivo es proporcionado por ex-liderazgo de OSHA.</p></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Enlaces Rápidos</h4><ul class=\"space-y-2 text-sm text-gray-300\"><li><a class=\"hover:text-white transition-colors\" href=\"/es/solutions\">Soluciones</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/es/services\">Servicios</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/es/contact\">Contacto</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/es/privacy-policy\">Política de Privacidad</a></li><li><a class=\"hover:text-white transition-colors\" href=\"https://app.safetylink.ai\">Ingresar</a></li></ul></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Cumplimiento y Confianza</h4><div class=\"text-sm text-gray-300 space-y-2\"><p>Safety Link, LLC</p><p>111 Congress Ave, Suite 500</p><p>Austin, Texas 78701</p><p class=\"pt-2\">888-373-7822</p><p>833-780-0728</p><p>compliance@safetylink.ai</p><div class=\"flex gap-1 items-center pt-2 text-xs text-primary\"><span>✓</span> OSHA Authorized Trainers</div><div class=\"flex gap-1 items-center text-xs text-primary\"><span>✓</span> SOC 2 Compliant</div></div></div></div><div class=\"border-t border-[rgba(255,255,255,0.1)] px-6 py-6\"><div class=\"max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400\"><p>© 2026 SafetyLink. Todos los derechos reservados. Soluciones de cumplimiento de seguridad legalmente defendibles.</p><div class=\"flex gap-6\"><a class=\"hover:text-white transition-colors\" href=\"/es/privacy-policy\">Política de Privacidad</a><a class=\"hover:text-white transition-colors\" href=\"/es/terms-of-service\">Términos de Servicio</a><a class=\"hover:text-white transition-colors\" href=\"/es/accessibility\">Accesibilidad</a></div></div></div></footer><!--$--><!--/$--></html><script src=\"/_next/static/chunks/3z5q_p4msz2ha.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n6:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"