{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/[lang]/layout,_N_T_/[lang]/safety-program-management/layout,_N_T_/[lang]/safety-program-management/page,_N_T_/es/safety-program-management"},"segmentPaths":["/_tree","/_full","/$d$lang/safety-program-management/__PAGE__","/$d$lang/safety-program-management","/$d$lang","/_index","/_head"]},"html":"<!DOCTYPE html><html class=\"open_sans_573b549b-module__BY3tqa__variable h-full antialiased\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/cf514f5d0007dafa-s.p.1wc2mf9hp9pav.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" as=\"image\" href=\"/images/Logos-SafetyLink-5.png\"/><link rel=\"preload\" href=\"/images/Logos-SafetyLink-1.png\" as=\"image\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/305zfmpkz2n9r.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/3z5q_p4msz2ha.js\"/><script src=\"/_next/static/chunks/15orcrkp-_9ct.js\" async=\"\"></script><script src=\"/_next/static/chunks/2nykiepra7i1k.js\" async=\"\"></script><script src=\"/_next/static/chunks/07u_h6i539_wj.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-3gtektv3c62t6.js\" async=\"\"></script><script src=\"/_next/static/chunks/05-c3ty_6dwfk.js\" async=\"\"></script><script src=\"/_next/static/chunks/14mrh2-p_w84d.js\" async=\"\"></script><script src=\"/_next/static/chunks/1-z_8zqv2wo99.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>SafetyLink | Legally Defensible Safety Compliance</title><meta name=\"description\" content=\"The Gold Standard in Legally Defensible Safety that Protects Your People and Your Business.\"/><link rel=\"icon\" href=\"/favicon.ico?favicon.2vob68tjqpejf.ico\" sizes=\"256x256\" type=\"image/x-icon\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><html lang=\"es\"><header class=\"bg-white shadow-sm sticky top-0 z-50\"><div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\"><a class=\"flex items-center gap-3\" href=\"/es\"><img src=\"/images/Logos-SafetyLink-5.png\" alt=\"SafetyLink\" class=\"h-10 w-auto\"/></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es\">Inicio</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/solutions\">Soluciones</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/services\">Servicios</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/about\">Nosotros</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/es/contact\">Contacto</a><a class=\"bg-primary text-white px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-[#009c2f] transition-colors\" href=\"/es/contact\">Solicitar Demo</a><a class=\"text-[#686868] font-medium text-sm hover:text-primary transition-colors\" href=\"https://app.safetylink.ai\">Ingresar</a><a class=\"text-xs text-navy font-semibold bg-[#eef3ff] px-3 py-1.5 rounded-full hover:bg-navy hover:text-white transition-all\" href=\"/en\">EN</a></nav><button class=\"lg:hidden text-navy p-2\" aria-label=\"Menu\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></header><main class=\"flex-1\"><section class=\"relative bg-navy text-white py-20 px-6\"><div class=\"max-w-4xl mx-auto text-center relative z-10\"><div class=\"flex flex-wrap justify-center gap-3 mb-6\"><span class=\"bg-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide\">Guiados por Ex-Liderazgo de OSHA</span><span class=\"bg-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide\">Impartido por Capacitadores Autorizados por OSHA</span><span class=\"bg-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide\">Bilingüe (EN/ES) por Defecto</span></div><h1 class=\"text-3xl md:text-5xl font-bold mb-4\">Gestión de Programas Safety Link</h1><p class=\"text-gray-300 text-lg mb-8\">Expertos dedicados. Programas específicos por sitio. Seguridad legalmente defendible.</p><div class=\"flex gap-4 justify-center flex-wrap\"><a class=\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \" href=\"/contact\">Solicitar Consultoría</a><a class=\"inline-block bg-transparent text-white border-2 border-white px-10 py-4 rounded-[10px] font-semibold text-sm hover:bg-white hover:text-navy transition-all \" href=\"/contact\">Hablar con un Asesor Autorizado por OSHA</a></div></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">🌐</div><h3 class=\"font-bold text-navy mb-2\">Bilingüe por defecto</h3><p class=\"text-[#666] text-sm\">Materiales de capacitación y programas en inglés y español.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">📋</div><h3 class=\"font-bold text-navy mb-2\">Impartido por autorizados OSHA</h3><p class=\"text-[#666] text-sm\">Expertos que construyen, capacitan y respaldan su programa.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">🏗️</div><h3 class=\"font-bold text-navy mb-2\">Programas específicos por sitio</h3><p class=\"text-[#666] text-sm\">Escritos para sus riesgos y lugares de trabajo—sin plantillas genéricas.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">⚖️</div><h3 class=\"font-bold text-navy mb-2\">Legalmente defendible</h3><p class=\"text-[#666] text-sm\">Asesorado por ex-liderazgo de OSHA y abogados laborales.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">🔍</div><h3 class=\"font-bold text-navy mb-2\">Auditorías en sitio</h3><p class=\"text-[#666] text-sm\">Encontramos lo que OSHA encontraría—y lo resolvemos juntos.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">📈</div><h3 class=\"font-bold text-navy mb-2\">Para PyMEs, escalable</h3><p class=\"text-[#666] text-sm\">Experiencia de alto nivel que escala a empresas de alto riesgo.</p></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-5xl mx-auto\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy text-center mb-10\">Qué Nos Hace el Estándar de Oro</h2><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">1</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Capacitación Obligatoria OSHA (EN/ES)</h3><p class=\"text-[#666] text-xs leading-relaxed\">Impartida por capacitadores autorizados por OSHA, programada y registrada para cubrir a toda su fuerza laboral.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">2</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Programas Personalizados por Sitio</h3><p class=\"text-[#666] text-xs leading-relaxed\">Políticas escritas para sus riesgos con control de versiones y acuses de recibo.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">3</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Evaluaciones de Riesgos en Sitio y Auditorías</h3><p class=\"text-[#666] text-xs leading-relaxed\">Identificamos violaciones y entregamos un plan de acción correctiva priorizado.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">4</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Defensa de Citaciones y Soporte OSHA</h3><p class=\"text-[#666] text-xs leading-relaxed\">Si OSHA aparece, nosotros aparecemos—orientación, representación y CAPA para minimizar citaciones.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">5</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Investigación y Prevención de Incidentes</h3><p class=\"text-[#666] text-xs leading-relaxed\">Análisis de causa raíz, documentación y estrategias de prevención para evitar repeticiones.</p></div></div></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-4xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy mb-8\">Complementos que Importan</h2><div class=\"flex flex-wrap justify-center gap-3\"><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Revisiones regulatorias</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Desarrollo cultural</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">JHAs/JSAs</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Planes de emergencia</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">EPP</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Seguridad de contratistas</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Registros OSHA</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Consultoría de riesgos/seguros</span></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-5xl mx-auto\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy text-center mb-2\">Nuestra Implementación</h2><p class=\"text-[#666] text-center mb-10 italic\">(<!-- -->Rápida, práctica, con rendición de cuentas<!-- -->)</p><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">1</div><h3 class=\"font-bold text-navy mb-2\">Inicio y Descubrimiento</h3><p class=\"text-[#666] text-xs leading-relaxed\">Mapeamos operaciones, riesgos y objetivos para que su plan sea realmente suyo.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">2</div><h3 class=\"font-bold text-navy mb-2\">Desarrollo del Programa</h3><p class=\"text-[#666] text-xs leading-relaxed\">Construimos políticas específicas alineadas con OSHA y su trabajo real.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">3</div><h3 class=\"font-bold text-navy mb-2\">Coordinación e Impartición de Capacitación</h3><p class=\"text-[#666] text-xs leading-relaxed\">Cursos requeridos por OSHA impartidos en sitio o remotamente (EN/ES).</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">4</div><h3 class=\"font-bold text-navy mb-2\">Revisiones 30/60/90 Días</h3><p class=\"text-[#666] text-xs leading-relaxed\">Seguimientos estructurados para asegurar adopción y mejora continua.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">5</div><h3 class=\"font-bold text-navy mb-2\">Éxito Continuo</h3><p class=\"text-[#666] text-xs leading-relaxed\">CSM dedicado + su AE para continuidad y un plan claro.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">6</div><h3 class=\"font-bold text-navy mb-2\">Opcional: Captura de Evidencia</h3><p class=\"text-[#666] text-xs leading-relaxed\">Si agrega el software SafetyLink, obtenga firmas electrónicas, registros de auditoría y registros OSHA.</p></div></div></div></section><section class=\"py-16 px-6 bg-navy text-white\"><div class=\"max-w-3xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold mb-8\">Oferta de Lanzamiento para Nuevos Clientes</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-left max-w-2xl mx-auto\"><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Evaluación de riesgos en sitio y auditoría de cumplimiento</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Programa bilingüe personalizado requerido por OSHA</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Primera ronda de capacitación OSHA (EN/ES)</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Consulta de 60 minutos con un Consultor de Seguridad Autorizado por OSHA</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Revisión de reclamos de compensación laboral y recomendaciones</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Todo incluido al iniciar Gestión de Programas</span></div></div></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-3xl mx-auto\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy text-center mb-10\">Preguntas Frecuentes</h2><div class=\"space-y-4\"><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">¿Necesito comprar software para trabajar con Safety Link?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">No. La Gestión de Programas funciona por sí sola. Puede agregar software después para captura de evidencia e informes.</div></details><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">¿Estarán presentes si OSHA visita?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">Sí. Apoyamos inspecciones y citaciones con orientación experta y planes de acción correctiva.</div></details><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">¿Todo es bilingüe?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">Sí—inglés y español son estándar en toda la capacitación y programas.</div></details><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">¿Qué tan rápido podemos estar en cumplimiento?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">Después del descubrimiento, implementamos políticas e impartimos capacitación de inmediato, luego impulsamos la adopción con revisiones de 30/60/90 días.</div></details></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-3xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy mb-4\">Su cumplimiento merece más que software genérico.</h2><p class=\"text-[#666] text-lg mb-8\">Obtenga un programa de seguridad bilingüe, específico por sitio y legalmente defendible—construido y gestionado por expertos Autorizados por OSHA.</p><div class=\"flex gap-4 justify-center flex-wrap\"><a class=\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \" href=\"/contact\">Solicitar Consultoría</a><a class=\"inline-block bg-white text-navy px-9 py-3.5 rounded-[10px] font-medium text-sm shadow-[rgba(0,0,0,0.3)_0px_0px_1px_0px] hover:shadow-md transition-all \" href=\"/contact\">Hablar con un Asesor</a></div></div></section></main><footer class=\"bg-navy text-white\"><div class=\"max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-10\"><div><img src=\"/images/Logos-SafetyLink-1.png\" alt=\"SafetyLink\" class=\"h-8 w-auto mb-4\"/><p class=\"text-gray-300 text-sm leading-relaxed mb-4\">La única plataforma de cumplimiento de seguridad legalmente defendible respaldada por ex-liderazgo de OSHA y expertos en derecho laboral. Protegiendo fuerzas laborales con capacitación, auditorías y soluciones de cumplimiento bilingües.</p><p class=\"text-xs text-gray-400 italic\">SafetyLink no está afiliado ni respaldado por OSHA. El apoyo consultivo es proporcionado por ex-liderazgo de OSHA.</p></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Enlaces Rápidos</h4><ul class=\"space-y-2 text-sm text-gray-300\"><li><a class=\"hover:text-white transition-colors\" href=\"/es/solutions\">Soluciones</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/es/services\">Servicios</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/es/contact\">Contacto</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/es/privacy-policy\">Política de Privacidad</a></li><li><a class=\"hover:text-white transition-colors\" href=\"https://app.safetylink.ai\">Ingresar</a></li></ul></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Cumplimiento y Confianza</h4><div class=\"text-sm text-gray-300 space-y-2\"><p>Safety Link, LLC</p><p>111 Congress Ave, Suite 500</p><p>Austin, Texas 78701</p><p class=\"pt-2\">888-373-7822</p><p>833-780-0728</p><p>compliance@safetylink.ai</p><div class=\"flex gap-1 items-center pt-2 text-xs text-primary\"><span>✓</span> OSHA Authorized Trainers</div><div class=\"flex gap-1 items-center text-xs text-primary\"><span>✓</span> SOC 2 Compliant</div></div></div></div><div class=\"border-t border-[rgba(255,255,255,0.1)] px-6 py-6\"><div class=\"max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400\"><p>© 2026 SafetyLink. Todos los derechos reservados. Soluciones de cumplimiento de seguridad legalmente defendibles.</p><div class=\"flex gap-6\"><a class=\"hover:text-white transition-colors\" href=\"/es/privacy-policy\">Política de Privacidad</a><a class=\"hover:text-white transition-colors\" href=\"/es/terms-of-service\">Términos de Servicio</a><a class=\"hover:text-white transition-colors\" href=\"/es/accessibility\">Accesibilidad</a></div></div></div></footer><!--$--><!--/$--></html><script src=\"/_next/static/chunks/3z5q_p4msz2ha.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n6:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"OutletBoundary\\\"]\\n7:\\\"$Sreact.suspense\\\"\\na:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"