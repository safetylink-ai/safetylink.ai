script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><html lang=\"en\"><header class=\"bg-white shadow-sm sticky top-0 z-50\"><div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\"><a class=\"flex items-center gap-3\" href=\"/en\"><img src=\"/images/Logos-SafetyLink-5.png\" alt=\"SafetyLink\" class=\"h-10 w-auto\"/></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en\">Home</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/solutions\">Solutions</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/services\">Services</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/about\">About</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/contact\">Contact</a><a class=\"bg-primary text-white px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-[#009c2f] transition-colors\" href=\"/en/contact\">Request Demo</a><a class=\"text-[#686868] font-medium text-sm hover:text-primary transition-colors\" href=\"https://app.safetylink.ai\">Login</a><a class=\"text-xs text-navy font-semibold bg-[#eef3ff] px-3 py-1.5 rounded-full hover:bg-navy hover:text-white transition-all\" href=\"/es\">ES</a></nav><button class=\"lg:hidden text-navy p-2\" aria-label=\"Menu\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></header><main class=\"flex-1\"><section class=\"relative bg-navy text-white py-20 px-6\"><div class=\"max-w-4xl mx-auto text-center relative z-10\"><div class=\"flex flex-wrap justify-center gap-3 mb-6\"><span class=\"bg-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide\">Guided by Former OSHA Leadership</span><span class=\"bg-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide\">Delivered by OSHA-Authorized Trainers</span><span class=\"bg-primary/20 text-primary text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide\">Bilingual (EN/ES) by Default</span></div><h1 class=\"text-3xl md:text-5xl font-bold mb-4\">Safety Link Program Management</h1><p class=\"text-gray-300 text-lg mb-8\">Hands-on experts. Site-specific programs. Legally defensible safety.</p><div class=\"flex gap-4 justify-center flex-wrap\"><a class=\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \" href=\"/contact\">Request a Consultation</a><a class=\"inline-block bg-transparent text-white border-2 border-white px-10 py-4 rounded-[10px] font-semibold text-sm hover:bg-white hover:text-navy transition-all \" href=\"/contact\">Talk to an OSHA Authorized Advisor</a></div></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">🌐</div><h3 class=\"font-bold text-navy mb-2\">Bilingual by default</h3><p class=\"text-[#666] text-sm\">Training &amp; program materials in English and Spanish.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">📋</div><h3 class=\"font-bold text-navy mb-2\">OSHA-Authorized delivery</h3><p class=\"text-[#666] text-sm\">Experts who build, train, and stand by your program.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">🏗️</div><h3 class=\"font-bold text-navy mb-2\">Site-specific programs</h3><p class=\"text-[#666] text-sm\">Written to your hazards &amp; jobsites—no generic templates.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">⚖️</div><h3 class=\"font-bold text-navy mb-2\">Legally defensible</h3><p class=\"text-[#666] text-sm\">Advised by former OSHA leadership &amp; OSHA attorneys.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">🔍</div><h3 class=\"font-bold text-navy mb-2\">On-site audits</h3><p class=\"text-[#666] text-sm\">We find what OSHA would find—and fix it together.</p></div><div class=\"text-center p-6 bg-[#f9fafb] rounded-2xl hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow\"><div class=\"text-3xl mb-3\">📈</div><h3 class=\"font-bold text-navy mb-2\">Built for SMBs, scalable</h3><p class=\"text-[#666] text-sm\">High-touch expertise that scales to high-risk enterprise.</p></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-5xl mx-auto\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy text-center mb-10\">What Makes Us the Gold Standard</h2><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">1</div><h3 class=\"font-bold text-navy mb-2 text-sm\">OSHA-Mandated Training (EN/ES)</h3><p class=\"text-[#666] text-xs leading-relaxed\">Delivered by OSHA Authorized trainers, scheduled and tracked so your whole workforce is covered.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">2</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Custom, Site-Specific Programs</h3><p class=\"text-[#666] text-xs leading-relaxed\">Policies written to your hazards &amp; jobsites with version control and acknowledgements.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">3</div><h3 class=\"font-bold text-navy mb-2 text-sm\">On-Site Hazard Assessments &amp; Compliance Audits</h3><p class=\"text-[#666] text-xs leading-relaxed\">We identify violations and deliver a prioritized corrective action plan.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">4</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Citation Defense &amp; OSHA Support</h3><p class=\"text-[#666] text-xs leading-relaxed\">If OSHA shows up, we show up—guidance, representation &amp; CAPA to minimize citations.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-navy/10 text-navy flex items-center justify-center mb-3 text-sm font-bold\">5</div><h3 class=\"font-bold text-navy mb-2 text-sm\">Incident Investigation &amp; Prevention</h3><p class=\"text-[#666] text-xs leading-relaxed\">Root-cause analysis, documentation, and prevention strategies to stop repeats.</p></div></div></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-4xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy mb-8\">Program Add-Ons That Matter</h2><div class=\"flex flex-wrap justify-center gap-3\"><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Regulatory reviews</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Culture development</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">JHAs/JSAs</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Emergency plans</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">PPE</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Contractor safety</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">OSHA logs</span><span class=\"bg-[#eef3ff] text-navy text-sm font-medium px-4 py-2 rounded-full\">Risk/insurance consulting</span></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-5xl mx-auto\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy text-center mb-2\">Our Implementation</h2><p class=\"text-[#666] text-center mb-10 italic\">(<!-- -->Fast, hands-on, accountable<!-- -->)</p><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">1</div><h3 class=\"font-bold text-navy mb-2\">Kickoff &amp; Discovery</h3><p class=\"text-[#666] text-xs leading-relaxed\">We map operations, hazards, and goals so your plan is actually yours.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">2</div><h3 class=\"font-bold text-navy mb-2\">Program Development</h3><p class=\"text-[#666] text-xs leading-relaxed\">We build site-specific policies aligned to OSHA and your real-world work.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">3</div><h3 class=\"font-bold text-navy mb-2\">Training Coordination &amp; Delivery</h3><p class=\"text-[#666] text-xs leading-relaxed\">OSHA-required courses delivered on-site or remotely (EN/ES).</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">4</div><h3 class=\"font-bold text-navy mb-2\">30/60/90-Day Check-ins</h3><p class=\"text-[#666] text-xs leading-relaxed\">Structured follow-ups to ensure adoption and continuous improvement.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">5</div><h3 class=\"font-bold text-navy mb-2\">Ongoing Success</h3><p class=\"text-[#666] text-xs leading-relaxed\">Dedicated CSM + your AE for continuity and a clear plan.</p></div><div class=\"bg-white rounded-2xl p-6 shadow-[0_4px_15px_0_rgba(0,0,0,0.08)]\"><div class=\"w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center mb-3 font-bold text-sm\">6</div><h3 class=\"font-bold text-navy mb-2\">Optional: Evidence Capture</h3><p class=\"text-[#666] text-xs leading-relaxed\">If you add SafetyLink software, get e-signatures, audit logs &amp; OSHA logs in one place.</p></div></div></div></section><section class=\"py-16 px-6 bg-navy text-white\"><div class=\"max-w-3xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold mb-8\">New-Customer Launch Offer</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-4 text-left max-w-2xl mx-auto\"><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">On-site hazard assessment &amp; compliance audit</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Custom bilingual OSHA-mandated program</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">First round of OSHA training (EN/ES)</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">60-minute consult with an OSHA-Authorized Safety Consultant</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">Workers&#x27; comp claims review &amp; recommendations</span></div><div class=\"flex items-start gap-3\"><span class=\"text-primary mt-0.5\">✓</span><span class=\"text-gray-200 text-sm\">All included when you start Program Management</span></div></div></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-3xl mx-auto\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy text-center mb-10\">FAQs</h2><div class=\"space-y-4\"><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">Do I need to buy software to work with Safety Link?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">No. Program Management stands on its own. You can add software later for evidence capture and reporting.</div></details><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">Will you be there if OSHA visits?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">Yes. We support inspections and citations with expert guidance and corrective action plans.</div></details><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">Is everything bilingual?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">Yes—English and Spanish are standard across training and programs.</div></details><details class=\"border border-gray-200 rounded-xl group\"><summary class=\"px-6 py-4 cursor-pointer font-semibold text-navy text-sm hover:bg-gray-50 transition-colors list-none flex justify-between items-center\">How fast can we be compliant?<span class=\"text-primary text-lg group-open:hidden\">+</span><span class=\"text-primary text-lg hidden group-open:inline\">−</span></summary><div class=\"px-6 pb-4 text-[#666] text-sm leading-relaxed\">After discovery, we implement policies and deliver required training immediately, then drive adoption with 30/60/90-day check-ins.</div></details></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-3xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy mb-4\">Your compliance deserves more than generic software.</h2><p class=\"text-[#666] text-lg mb-8\">Get a bilingual, site-specific, legally defensible safety program—built and run by OSHA Authorized experts.</p><div class=\"flex gap-4 justify-center flex-wrap\"><a class=\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \" href=\"/contact\">Request a Consultation</a><a class=\"inline-block bg-white text-navy px-9 py-3.5 rounded-[10px] font-medium text-sm shadow-[rgba(0,0,0,0.3)_0px_0px_1px_0px] hover:shadow-md transition-all \" href=\"/contact\">Talk to an Advisor</a></div></div></section></main><footer class=\"bg-navy text-white\"><div class=\"max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-10\"><div><img src=\"/images/Logos-SafetyLink-1.png\" alt=\"SafetyLink\" class=\"h-8 w-auto mb-4\"/><p class=\"text-gray-300 text-sm leading-relaxed mb-4\">The only legally defensible safety compliance platform backed by OSHA leadership and top labor law experts. Protecting workforces with bilingual training, audits, and compliance solutions.</p><p class=\"text-xs text-gray-400 italic\">SafetyLink is not affiliated with or endorsed by OSHA. Advisory support provided by former OSHA leadership.</p></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Quick Links</h4><ul class=\"space-y-2 text-sm text-gray-300\"><li><a class=\"hover:text-white transition-colors\" href=\"/en/solutions\">Solutions</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/en/services\">Services</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/en/contact\">Contact</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/en/privacy-policy\">Privacy Policy</a></li><li><a class=\"hover:text-white transition-colors\" href=\"https://app.safetylink.ai\">Login</a></li></ul></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Compliance &amp; Trust</h4><div class=\"text-sm text-gray-300 space-y-2\"><p>Safety Link, LLC</p><p>111 Congress Ave, Suite 500</p><p>Austin, Texas 78701</p><p class=\"pt-2\">888-373-7822</p><p>833-780-0728</p><p>compliance@safetylink.ai</p><div class=\"flex gap-1 items-center pt-2 text-xs text-primary\"><span>✓</span> OSHA Authorized Trainers</div><div class=\"flex gap-1 items-center text-xs text-primary\"><span>✓</span> SOC 2 Compliant</div></div></div></div><div class=\"border-t border-[rgba(255,255,255,0.1)] px-6 py-6\"><div class=\"max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400\"><p>© 2026 SafetyLink. All rights reserved. Legally defensible safety compliance solutions.</p><div class=\"flex gap-6\"><a class=\"hover:text-white transition-colors\" href=\"/en/privacy-policy\">Privacy Policy</a><a class=\"hover:text-white transition-colors\" href=\"/en/terms-of-service\">Terms of Service</a><a class=\"hover:text-white transition-colors\" href=\"/en/accessibility\">Accessibility</a></div></div></div></footer><!--$--><!--/$--></html><script src=\"/_next/static/chunks/3z5q_p4msz2ha.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n6:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"OutletBoundary\\\"]\\n7:\\\"$Sreact.suspense\\\"\\na:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"ViewportBoundary\\\"]\\nc:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"MetadataBoundary\\\"]\\ne:I[68027,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\",1]\\n:HL[\\\"/_next/static/chunks/305zfmpkz2n9r.css\\\",\\\"style\\\"]\\n:HL[\\\"/_next/static/media/cf514f5d0007dafa-s.p.1wc2mf9hp9pav.woff2\\\",\\\"font\\\",{\\\"crossOrigin\\\":\\\"\\\",\\\"type\\\":\\\"font/woff2\\\"}]\\n\"])</script><script>s