ody class=\"min-h-full flex flex-col\"><div hidden=\"\"><!--$--><!--/$--></div><html lang=\"en\"><header class=\"bg-white shadow-sm sticky top-0 z-50\"><div class=\"max-w-7xl mx-auto px-6 h-20 flex items-center justify-between\"><a class=\"flex items-center gap-3\" href=\"/en\"><img src=\"/images/Logos-SafetyLink-5.png\" alt=\"SafetyLink\" class=\"h-10 w-auto\"/></a><nav class=\"hidden lg:flex items-center gap-8\"><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en\">Home</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/solutions\">Solutions</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/services\">Services</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/about\">About</a><a class=\"text-[#333] font-medium text-sm hover:text-primary transition-colors\" href=\"/en/contact\">Contact</a><a class=\"bg-primary text-white px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-[#009c2f] transition-colors\" href=\"/en/contact\">Request Demo</a><a class=\"text-[#686868] font-medium text-sm hover:text-primary transition-colors\" href=\"https://app.safetylink.ai\">Login</a><a class=\"text-xs text-navy font-semibold bg-[#eef3ff] px-3 py-1.5 rounded-full hover:bg-navy hover:text-white transition-all\" href=\"/es\">ES</a></nav><button class=\"lg:hidden text-navy p-2\" aria-label=\"Menu\"><svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></header><main class=\"flex-1\"><section class=\"bg-navy text-white py-20 px-6 text-center\"><div class=\"max-w-3xl mx-auto\"><h1 class=\"text-3xl md:text-5xl font-bold mb-4\">Our Services</h1><p class=\"text-gray-300 text-lg\">Comprehensive safety and compliance solutions tailored to your business.</p></div></section><section class=\"py-16 px-6 bg-white\"><div class=\"max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\"><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">🔍</div><h3 class=\"font-bold text-navy mb-2\">Safety Audits &amp; Inspections</h3><p class=\"text-[#666] text-sm\">On-site hazard assessments and compliance audits to identify risks before OSHA does.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">📚</div><h3 class=\"font-bold text-navy mb-2\">OSHA Training (EN/ES)</h3><p class=\"text-[#666] text-sm\">Bilingual training delivered by OSHA-authorized trainers — on-site or remote.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">📋</div><h3 class=\"font-bold text-navy mb-2\">Policy &amp; Program Development</h3><p class=\"text-[#666] text-sm\">Site-specific safety policies, JHAs, JSAs, and emergency plans.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">⚖️</div><h3 class=\"font-bold text-navy mb-2\">Citation Defense &amp; Support</h3><p class=\"text-[#666] text-sm\">If OSHA shows up, we show up — guidance, representation, and corrective action plans.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">🔎</div><h3 class=\"font-bold text-navy mb-2\">Incident Investigation</h3><p class=\"text-[#666] text-sm\">Root-cause analysis, documentation, and prevention strategies.</p></div><div class=\"bg-[#f9fafb] rounded-2xl p-6 hover:shadow-[0_4px_15px_0_rgba(0,0,0,0.08)] transition-shadow text-center\"><div class=\"text-3xl mb-3\">🛡️</div><h3 class=\"font-bold text-navy mb-2\">Risk &amp; Insurance Consulting</h3><p class=\"text-[#666] text-sm\">Workers&#x27; comp claims review, risk assessments, and recommendations.</p></div></div></section><section class=\"py-16 px-6\" style=\"background:linear-gradient(rgb(255,255,255) 0%, rgb(244,243,242) 100%)\"><div class=\"max-w-3xl mx-auto text-center\"><h2 class=\"text-2xl md:text-3xl font-bold text-navy mb-4\">Not sure what you need?</h2><p class=\"text-[#666] text-lg mb-8\">Talk to an OSHA Authorized Advisor — we&#x27;ll help you find the right solution.</p><a class=\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \" href=\"/contact\">Request a Consultation</a></div></section></main><footer class=\"bg-navy text-white\"><div class=\"max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-10\"><div><img src=\"/images/Logos-SafetyLink-1.png\" alt=\"SafetyLink\" class=\"h-8 w-auto mb-4\"/><p class=\"text-gray-300 text-sm leading-relaxed mb-4\">The only legally defensible safety compliance platform backed by OSHA leadership and top labor law experts. Protecting workforces with bilingual training, audits, and compliance solutions.</p><p class=\"text-xs text-gray-400 italic\">SafetyLink is not affiliated with or endorsed by OSHA. Advisory support provided by former OSHA leadership.</p></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Quick Links</h4><ul class=\"space-y-2 text-sm text-gray-300\"><li><a class=\"hover:text-white transition-colors\" href=\"/en/solutions\">Solutions</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/en/services\">Services</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/en/contact\">Contact</a></li><li><a class=\"hover:text-white transition-colors\" href=\"/en/privacy-policy\">Privacy Policy</a></li><li><a class=\"hover:text-white transition-colors\" href=\"https://app.safetylink.ai\">Login</a></li></ul></div><div><h4 class=\"font-bold text-sm uppercase tracking-wider mb-4\">Compliance &amp; Trust</h4><div class=\"text-sm text-gray-300 space-y-2\"><p>Safety Link, LLC</p><p>111 Congress Ave, Suite 500</p><p>Austin, Texas 78701</p><p class=\"pt-2\">888-373-7822</p><p>833-780-0728</p><p>compliance@safetylink.ai</p><div class=\"flex gap-1 items-center pt-2 text-xs text-primary\"><span>✓</span> OSHA Authorized Trainers</div><div class=\"flex gap-1 items-center text-xs text-primary\"><span>✓</span> SOC 2 Compliant</div></div></div></div><div class=\"border-t border-[rgba(255,255,255,0.1)] px-6 py-6\"><div class=\"max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-400\"><p>© 2026 SafetyLink. All rights reserved. Legally defensible safety compliance solutions.</p><div class=\"flex gap-6\"><a class=\"hover:text-white transition-colors\" href=\"/en/privacy-policy\">Privacy Policy</a><a class=\"hover:text-white transition-colors\" href=\"/en/terms-of-service\">Terms of Service</a><a class=\"hover:text-white transition-colors\" href=\"/en/accessibility\">Accessibility</a></div></div></div></footer><!--$--><!--/$--></html><script src=\"/_next/static/chunks/3z5q_p4msz2ha.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[39756,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n3:I[37457,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"default\\\"]\\n6:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"OutletBoundary\\\"]\\n7:\\\"$Sreact.suspense\\\"\\na:I[97367,[\\\"/_next/static/chunks/05-c3ty_6dwfk.js\\\",\\\"/_next/static/chunks/14mrh2-p_w84d.js\\\"],\\\"ViewportBoundary\\\"]\\nc:I[97367,[\\\"/_next/st