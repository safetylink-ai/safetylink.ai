\":\"text-amber-400 mb-4\",\"children\":\"★★★★★\"}],[\"$\",\"p\",null,{\"className\":\"text-[#666] text-sm leading-relaxed mb-6 italic\",\"children\":[\"“\",\"SafetyLink transformó nuestro programa de cumplimiento. La defendibilidad legal nos da la confianza de que estamos realmente protegidos.\",\"”\"]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-navy text-sm\",\"children\":\"Maria Rodriguez\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-[#686868]\",\"children\":\"Directora de Seguridad, Manufactura\"}]]}]]}],[\"$\",\"div\",\"1\",{\"className\":\"bg-white rounded-2xl p-8 shadow-[0_10px_28px_0_rgba(0,0,0,0.12)]\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-amber-400 mb-4\",\"children\":\"★★★★★\"}],[\"$\",\"p\",null,{\"className\":\"text-[#666] text-sm leading-relaxed mb-6 italic\",\"children\":[\"“\",\"La plataforma bilingüe de SafetyLink hizo que capacitar a nuestra fuerza laboral diversa fuera impecable.\",\"”\"]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-navy text-sm\",\"children\":\"Ana Gutierrez\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-[#686868]\",\"children\":\"Coordinadora de Seguridad, Transporte\"}]]}]]}],[\"$\",\"div\",\"2\",{\"className\":\"bg-white rounded-2xl p-8 shadow-[0_10px_28px_0_rgba(0,0,0,0.12)]\",\"children\":[[\"$\",\"div\",null,{\"className\":\"text-amber-400 mb-4\",\"children\":\"★★★★★\"}],[\"$\",\"p\",null,{\"className\":\"text-[#666] text-sm leading-relaxed mb-6 italic\",\"children\":[\"“\",\"SafetyLink simplificó todo nuestro programa de seguridad con resultados medibles.\",\"”\"]}],[\"$\",\"div\",null,{\"children\":[[\"$\",\"p\",null,{\"className\":\"font-bold text-navy text-sm\",\"children\":\"David Kim\"}],[\"$\",\"p\",null,{\"className\":\"text-xs text-[#686868]\",\"children\":\"Director de Seguridad, Manufactura\"}]]}]]}]]}]]}]}]\ne:[\"$\",\"$L13\",null,{\"heading\":\"Preguntas Frecuentes\",\"items\":[{\"q\":\"¿Qué hace diferente a SafetyLink?\",\"a\":\"Combinamos consultoría autorizada por OSHA, software potente y soporte bilingüe integrado. Soluciones integrales, no solo auditorías.\"},{\"q\":\"¿Necesito comprar software?\",\"a\":\"No — ofrecemos modelos flexibles que incluyen consultoría independiente, gestión de programas o software. Puede comenzar con una auditoría única.\"},{\"q\":\"¿Es adecuado para pequeñas empresas?\",\"a\":\"Sí — nos especializamos en PyMEs, ofreciendo experiencia de nivel empresarial a precios accesibles. Escalable de 10 a más de 10,000 trabajadores.\"},{\"q\":\"¿Qué tan rápido podemos estar en cumplimiento?\",\"a\":\"Desde el momento en que nos comprometemos, nos movemos. Soporte inmediato en sitio para resolver problemas de alto riesgo, impartir capacitación e instalar controles.\"},{\"q\":\"¿La capacitación es bilingüe?\",\"a\":\"Integrada en todos los servicios — materiales, señalización y comunicación directa con la fuerza laboral en español e inglés.\"}]}]\nf:[\"$\",\"section\",null,{\"className\":\"py-20 px-6 bg-navy text-white text-center\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-3xl mx-auto\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-3xl md:text-4xl font-bold mb-4\",\"children\":\"¿Listo para Proteger a su Gente y su Negocio?\"}],[\"$\",\"p\",null,{\"className\":\"text-gray-300 text-lg mb-10\",\"children\":\"Experimente la diferencia que la experiencia autorizada por OSHA y el liderazgo comprobado pueden hacer.\"}],[\"$\",\"div\",null,{\"className\":\"flex gap-4 justify-center flex-wrap\",\"children\":[[\"$\",\"$L3\",null,{\"href\":\"/contact\",\"className\":\"inline-block bg-primary text-white px-10 py-4 rounded-full font-semibold text-sm hover:bg-[#009c2f] shadow-[0_2px_6px_0_rgba(0,183,55,0.25)] transition-all \",\"children\":\"Solicitar Demo\"}],[\"$\",\"$L3\",null,{\"href\":\"/contact\",\"className\":\"inline-block bg-transparent text-white border-2 border-white px-10 py-4 rounded-[10px] font-semibold text-sm hove